# Merged UI: `/coti`, `/sepolia`, `/avalanche` — copy to `.env` and restart `npm run dev` after changes.

# Master secret for encrypted private keys (see src/lib/KeyUtils.js). Never commit ENC_K.
ENC_K=

# --- COTI Testnet (`/coti`) — native MPC, uint64 wealth ---
VITE_CONTRACT_ADDRESS_COTI_TESTNET=
COTI_TESTNET_RPC_URL=https://testnet.coti.io/rpc

# --- Sepolia PoD (`/sepolia`) ---
VITE_CONTRACT_ADDRESS_SEPOLIA=
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# --- Avalanche Fuji PoD (`/avalanche`) — chain id 43113 ---
# Before deploy: set the Fuji inbox in src/lib/pod/defaults.js (AVALANCHE_FUJI_DEFAULT_INBOX_ADDRESS);
# the deploy script applies it via the contract's configure().
VITE_CONTRACT_ADDRESS_AVALANCHE_FUJI=
AVALANCHE_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Shared PoD players (same keys for Sepolia and Avalanche demos)
VITE_ALICE_PK=
VITE_ALICE_AES_KEY=
VITE_BOB_PK=
VITE_BOB_AES_KEY=

# PoD wealth: decimal → wei (`VITE_WEALTH_DECIMALS`, default 18)
# VITE_WEALTH_DECIMALS=18

# PoD encryption API (`testnet` | `mainnet` | full URL)
# VITE_POD_ENCRYPTION_NETWORK=testnet

# PoD request explorer (tracker dialog); use `{requestId}` placeholder
# VITE_POD_REQUEST_EXPLORER_URL=
# VITE_POD_REQUEST_EXPLORER_URL_AVALANCHE=

# Optional: COTI testnet PoD inbox override
# VITE_POD_COTI_INBOX_ADDRESS=

# --- Hardhat deploy ---
DEPLOYER_PRIVATE_KEY=
ETHERSCAN_API_KEY=
