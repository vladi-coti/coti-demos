VITE_COTI_RPC_URL=https://testnet.coti.io/rpc
VITE_SOURCE_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-key

# Shared frontend wallets. Native mode uses the COTI wallet directly.
# PoD mode uses the same keys for Sepolia tx signing + COTI decryption unless you override them with VITE_POD_* values.
VITE_OWNER_PK=your_owner_private_key_without_0x
VITE_OWNER_AES_KEY=your_owner_aes_key
VITE_APPROVER_PK=your_approver_private_key_without_0x
VITE_APPROVER_AES_KEY=your_approver_aes_key

# Native COTI mode
VITE_NATIVE_COTI_RPC_URL=https://testnet.coti.io/rpc
VITE_NATIVE_COTI_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_NATIVE_DEFAULT_RECIPIENT=0x00000000000000000000000000000000000000A1
VITE_NATIVE_DEFAULT_APPROVERS=0x0000000000000000000000000000000000000000
VITE_NATIVE_DEFAULT_DESCRIPTION_HASH=0x1111111111111111111111111111111111111111111111111111111111111111

# Sepolia + PoD mode
VITE_POD_SOURCE_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-key
VITE_POD_COTI_RPC_URL=https://testnet.coti.io/rpc
VITE_POD_SOURCE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_POD_COTI_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_POD_COTI_INBOX_ADDRESS=0x0000000000000000000000000000000000000000
VITE_POD_CALLBACK_FEE_WEI=1000000000000000
VITE_POD_CREATE_TOTAL_FEE_WEI=3000000000000000
VITE_POD_APPROVAL_TOTAL_FEE_WEI=3000000000000000
VITE_POD_FINALIZE_TOTAL_FEE_WEI=3000000000000000
VITE_POD_DEFAULT_RECIPIENT=0x00000000000000000000000000000000000000A1
VITE_POD_DEFAULT_APPROVERS=0x0000000000000000000000000000000000000000
VITE_POD_DEFAULT_DESCRIPTION_HASH=0x1111111111111111111111111111111111111111111111111111111111111111

# Legacy fallback keys still supported by the app
VITE_DEFAULT_RECIPIENT=0x00000000000000000000000000000000000000A1
VITE_DEFAULT_APPROVERS=0x0000000000000000000000000000000000000000
VITE_DEFAULT_DESCRIPTION_HASH=0x1111111111111111111111111111111111111111111111111111111111111111

# Hardhat deploy config
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_without_0x
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-key
COTI_TESTNET_RPC_URL=https://testnet.coti.io/rpc
SEPOLIA_INBOX_ADDRESS=0x0000000000000000000000000000000000000000
COTI_INBOX_ADDRESS=0x0000000000000000000000000000000000000000
PRIVATE_TREASURY_APPROVAL_COTI_ADDRESS=0x0000000000000000000000000000000000000000
COTI_CHAIN_ID=7082400
