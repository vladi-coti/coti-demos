VITE_COTI_RPC_URL=https://testnet.coti.io/rpc

# Frontend wallets. Use the same EOA on source + COTI if you want decryption to work.
VITE_OWNER_PK=your_owner_private_key_without_0x
VITE_OWNER_AES_KEY=your_owner_aes_key
VITE_APPROVER_PK=your_approver_private_key_without_0x
VITE_APPROVER_AES_KEY=your_approver_aes_key

# Deployed addresses
VITE_SOURCE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_COTI_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_SOURCE_INBOX_ADDRESS=0x0000000000000000000000000000000000000000
VITE_COTI_INBOX_ADDRESS=0x0000000000000000000000000000000000000000

# Cross-chain fee assumptions for the demo shell.
VITE_CALLBACK_FEE_WEI=1000000000000000
VITE_CREATE_TOTAL_FEE_WEI=3000000000000000
VITE_APPROVAL_TOTAL_FEE_WEI=3000000000000000
VITE_FINALIZE_TOTAL_FEE_WEI=3000000000000000

# Default proposal values used to prefill the demo UI.
VITE_DEFAULT_RECIPIENT=0x00000000000000000000000000000000000000A1
VITE_DEFAULT_APPROVERS=0x0000000000000000000000000000000000000000
VITE_DEFAULT_DESCRIPTION_HASH=0x1111111111111111111111111111111111111111111111111111111111111111

# Hardhat deploy config
